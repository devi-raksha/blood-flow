subsection BloodFlowSystem<1, 3>
  set Finite element degree                = 2
  set Number of global refinement          = 8
  set Number of refinement cycles          = 1
  set Numerical flux type                  = HLL
  set Outlet boundary condition type       = Rt
  set Output filename                      = solution
  set Problem constants                    = 1.0
  set Theta Boundary (stability parameter) = 0.5
  set Theta (penalty parameter)            = 0.5
  set Use Riemann Invariants               = true
  set Use direct solver                    = true
  set Use junction mesh                    = false
  set Verbosity (console depth)            = 1
  subsection ARKOde parameters
    set Final time                        = 1.5
    set Initial time                      = 0
    set Time interval between each output = 0.01
    subsection Error control
      set Absolute error tolerance = 1e-06 
      set Relative error tolerance = 1e-05
    end
    subsection Running parameters
      set Anderson-acceleration subspace         = 3
      set Implicit function is linear            = false
      set Implicit function is time independent  = false
      set Initial step size                      = 1e-3
      set Mass is time independent               = true
      set Maximum number of nonlinear iterations = 10
      set Maximum order of ARK                   = 5
      set Minimum step size                      = 1e-06
    end
  end
end
subsection Blood Flow Parameters
  set Capacitance of terminal capacitor (C)           = 5.0e-10
  set Density (rho)                                   = 1050.0
  set Diastolic pressure (p_d)                        = 0
  set Elastic modulus of the vessel wall (E)          = 4e5
  set Length of the vessel (L)                        = 10.0
  set Pressure at terminal boundary (P_out)           = 0
  set Reference cross-sectional area (a0)             = 3.14e-4
  set Area at diastolic pressure (a_d)                = 3.14e-4
  set Reference pressure (p0)                         = 0
  set Reference radius (r0)                           = 0.0100
  set Reflection coefficient at outflow boundary (Rt) = 0.0
  set Resistance of distal capacitor (R2)             = 1.1e9 
  set Resistance of proximal capacitor (R1)           = 1.2e8
  set Tube law exponent (m)                           = 0.5
  set Viscosity coefficient (mu)                      = 0
  set Profile constant for friction term (xi)         = 9.0
  set Wall thickness (h_wall)                         = 0.0015
end
subsection Functions
  set Exact solution    = 1e-4; 0.0
  set Inflow function   = 1e-6 * exp(-10000*(t-0.05)^2) 
  set Initial condition = a0; 0.0
  set RHS expression    = 0.0; 0.0
end
