subsection Blood Flow Parameters
  set Density (rho)                           = 1
  set Elastic modulus of the vessel wall (mu) = 1
  set Reference cross-sectional area (a0)     = 1
  set Reference pressure (p0)                 = 1
  set Reference radius (r0)                   = 1
  set Tube law exponent (m)                   = .5
  set Viscosity coefficient (eta_c)           = 1
end

subsection Functions
   set Exact solution = 1; 1
   set Initial condition = 1; 1
   set RHS expression = 0; eta_c
end

subsection BloodFlowSystem<1, 3>
  set Finite element degree        = 1
  set Number of global refinement  = 5
  set Number of refinement cycles  = 1
  set Output filename              = solution
  set Theta (penalty parameter)    = 0
  set Theta Boundary (stability parameter) = 0
  set Use direct solver            = true
  set Verbosity (console depth)    = 1
  subsection ARKOde parameters
    set Initial time                      = 0
    set Final time                        = 1
    set Time interval between each output = 1
    subsection Error control
      set Absolute error tolerance = 1e-8
      set Relative error tolerance = 1e-8
    end
    subsection Running parameters
      set Initial step size                      = 0.1
      set Minimum step size                      = 1e-08
      set Mass is time independent               = true
      set Implicit function is time independent  = true
      set Implicit function is linear            = false
      set Maximum number of nonlinear iterations = 10
      set Maximum order of ARK                   = 4
    end
  end
end
